# DummyJSON REST API base URL.
# Uygulama bu değer olmadan da varsayılanla çalışır (src/constants/config.ts).
# Farklı bir ortam/proxy kullanacaksan bu dosyayı ".env" olarak kopyalayıp değeri değiştir.
EXPO_PUBLIC_API_BASE_URL=https://dummyjson.com

# API istekleri için zaman aşımı (ms)
EXPO_PUBLIC_API_TIMEOUT_MS=12000
